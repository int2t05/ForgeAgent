# 复制为仓库根或 backend 目录下的 .env（勿提交含真实密钥的 .env）
# 环境变量名与 backend/app/core/config.py 中字段对应：全大写 + 下划线（Pydantic Settings 默认规则）。

# ---------------------------------------------------------------------------
# 前端（仅 VITE_* 会进入浏览器打包，勿写密钥）
# ---------------------------------------------------------------------------
VITE_API_BASE_URL=http://127.0.0.1:8000
# 底栏上下文用量环分母，与后端 LLM_CONTEXT_WINDOW_TOKENS 保持一致为宜
# VITE_LLM_CONTEXT_WINDOW_TOKENS=204800

# ---------------------------------------------------------------------------
# 数据库（SQLAlchemy / 任务与会话）
# ---------------------------------------------------------------------------
# DATABASE_URL=sqlite+aiosqlite:///./forgeagent.db

# ---------------------------------------------------------------------------
# LangGraph 检查点（与业务库文件分离；相对路径相对进程 CWD）
# ---------------------------------------------------------------------------
# LANGGRAPH_CHECKPOINT_SQLITE_PATH=./db_checkpoints/langgraph_checkpoints.db
# 可选：Postgres 存检查点（需 pip install -e ".[checkpoint-postgres]"）
# LANGGRAPH_CHECKPOINT_POSTGRES_URI=

# ---------------------------------------------------------------------------
# HTTP（CORS：须与实际访问前端的 Origin 一致，逗号分隔）
# ---------------------------------------------------------------------------
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# ---------------------------------------------------------------------------
# Agent：重规划、会话记忆窗口、每步工具重试
# ---------------------------------------------------------------------------
# MAX_REPLAN_ATTEMPTS=3
# 规划输出 JSON 解析/校验失败时，最多完整规划 LLM 调用轮数（含首轮）
# PLANNER_PARSE_MAX_ATTEMPTS=3
# Learner 反思 JSON 解析失败或 reflection 为空时，最多完整调用轮数（含首轮）
# LEARNER_PARSE_MAX_ATTEMPTS=3
# SESSION_MEMORY_MAX_MESSAGES=32
# 超长会话：条数超过阈值则 LLM 摘要较早消息，保留最近原文条数
# SESSION_CONVERSATION_SUMMARY_ENABLED=true
# SESSION_SUMMARIZE_WHEN_OVER=20
# SESSION_SUMMARY_KEEP_RECENT=10
# SESSION_SUMMARY_LINE_MAX_CHARS=400
# SESSION_SUMMARY_MAX_ANSWER_CHARS=500
# SESSION_BLACKBOARD_MAX_NOTES=64
# MAX_TOOL_FAILURE_ATTEMPTS=3
# 单条 plan 步内 ReAct 最大轮数（每轮可含一批工具调用 + Observation）
# MAX_REACT_ROUNDS_PER_STEP=20
# 单步 ReAct 助手输出 token 粗估上限（0=关闭；约 4 字符/token）
# REACT_MAX_TOKENS_PER_STEP=8000
# 单条 Observation JSON 注入 LLM 前的最大字符数（工具大返回截断）
# REACT_TOOL_OBSERVATION_MAX_JSON_CHARS=12000
# 内置工具默认/分类超时（秒，另见 SHELL/PYTHON_REPL）
# TOOL_DEFAULT_TIMEOUT_SEC=30
# TOOL_SEARCH_TIMEOUT_SEC=10
# TOOL_FILE_TIMEOUT_SEC=5
# 工具失败重试之间的退避（秒）
# TOOL_RETRY_BASE_DELAY_SEC=0.5
# TOOL_RETRY_MAX_DELAY_SEC=8
# 熔断：连续失败次数与恢复等待（秒）
# CIRCUIT_BREAKER_LLM_FAILURE_THRESHOLD=5
# CIRCUIT_BREAKER_LLM_RECOVERY_SEC=60
# CIRCUIT_BREAKER_TOOL_FAILURE_THRESHOLD=10
# CIRCUIT_BREAKER_TOOL_RECOVERY_SEC=60

# ---------------------------------------------------------------------------
# 内置工具：工作区、搜索、Python REPL、Shell
# ---------------------------------------------------------------------------
# AGENT_WORKSPACE_ROOT=
# TAVILY_API_KEY=
# AGENT_ENABLE_PYTHON_REPL=true
# PYTHON_REPL_TIMEOUT_SEC=120
# AGENT_ENABLE_SHELL_TOOL=false
# SHELL_TOOL_TIMEOUT_SEC=120

# ---------------------------------------------------------------------------
# LLM：OpenAI 兼容（留空则规划/总结可走内置确定性路径，便于 CI）
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=
# OPENAI_API_BASE=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_REQUEST_TIMEOUT=120
# OPENAI_MAX_RETRIES=3

# ---------------------------------------------------------------------------
# LLM：应用层拥塞/529 等退避（ainvoke_with_retry）
# ---------------------------------------------------------------------------
# OPENAI_RETRY_MAX_ATTEMPTS=8
# OPENAI_RETRY_BASE_DELAY_SEC=1.5
# OPENAI_RETRY_MAX_DELAY_SEC=60

# ---------------------------------------------------------------------------
# LLM：上下文预算（与网关/模型窗口对齐，避免 400 context length）
# 默认按约 20 万上下文类模型（如 MiniMax-M2.7）；8k/128k 等小窗口模型请改小。
# ---------------------------------------------------------------------------
# LLM_CONTEXT_WINDOW_TOKENS=204800
# LLM_RESERVED_COMPLETION_TOKENS=8192
# LLM_USE_EXACT_TOKEN_COUNT=true
