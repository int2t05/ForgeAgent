# 复制为 .env 并按需填写（勿将真实密钥提交到仓库）

# 前端（仅 VITE_* 会注入浏览器）
VITE_API_BASE_URL=http://127.0.0.1:8000

# 后端（示例占位，实现业务时再使用）
# 逗号分隔；须与浏览器打开前端的 Origin 一致（localhost 与 127.0.0.1 不同源）
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# OpenAI 兼容（规划 + 对话回复；留空则走内置确定性逻辑）
# OPENAI_API_KEY=
# OPENAI_API_BASE=
# OPENAI_MODEL=gpt-4o-mini
# LLM 请求超时（秒，默认 120）；≤0 使用库默认
# OPENAI_REQUEST_TIMEOUT=120
# OPENAI_MAX_RETRIES=2
# DATABASE_URL=sqlite+aiosqlite:///./forgeagent.db
# Agent：单次任务允许的重规划次数（可选，默认 3）
# MAX_REPLAN_ATTEMPTS=3
# ReAct 路径下单任务「推理-行动」最大轮次（可选，默认 8）
# MAX_REACT_ITERATIONS=8
# 多轮规划：注入 LLM 的最近会话消息条数上限（可选，默认 32）
# SESSION_MEMORY_MAX_MESSAGES=32
# LangGraph 检查点：默认 SQLite 文件路径（相对进程工作目录）
# LANGGRAPH_CHECKPOINT_SQLITE_PATH=./data/langgraph_checkpoints.db
# 若使用 Postgres 存检查点，设置 URI 并在 backend 目录执行: pip install -e ".[checkpoint-postgres]"
# LANGGRAPH_CHECKPOINT_POSTGRES_URI=postgresql://user:pass@localhost:5432/dbname
