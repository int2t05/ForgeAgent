# 复制为 .env 并按需填写（勿将真实密钥提交到仓库）

# 前端（仅 VITE_* 会注入浏览器）
VITE_API_BASE_URL=http://127.0.0.1:8000

# 后端（示例占位，实现业务时再使用）
# 逗号分隔；须与浏览器打开前端的 Origin 一致（localhost 与 127.0.0.1 不同源）
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Tavily 搜索（启用内置 tavily_search；留空则仅注册 DuckDuckGo）
# TAVILY_API_KEY=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
# Agent 工作区：内置 read_file / write_file / list_directory 仅允许该目录下路径；留空=仓库根；可填相对仓库的路径或绝对路径
# AGENT_WORKSPACE_ROOT=
# 是否注册 python_repl（任意代码执行，默认 true）
# AGENT_ENABLE_PYTHON_REPL=true
# python_repl 单次执行墙钟上限（秒，默认 120；代码内 subprocess.run 无 timeout 会占满该时间）
# PYTHON_REPL_TIMEOUT_SEC=120
# 是否注册 shell（任意系统命令，默认 false）
# AGENT_ENABLE_SHELL_TOOL=false
# Shell 子进程超时（秒，默认 120；防止交互脚本挂死整轮 ReAct）
# SHELL_TOOL_TIMEOUT_SEC=120
# OpenAI 兼容（规划 + 对话回复；留空则走内置确定性逻辑）
# OPENAI_API_KEY=
# OPENAI_API_BASE=
# OPENAI_MODEL=gpt-4o-mini
# LLM 请求超时（秒，默认 120）；≤0 使用库默认
# OPENAI_REQUEST_TIMEOUT=120
# OPENAI_MAX_RETRIES=3
# 应用层：过载/529/限流等指数退避（总尝试次数含首次）
# OPENAI_RETRY_MAX_ATTEMPTS=8
# OPENAI_RETRY_BASE_DELAY_SEC=1.5
# OPENAI_RETRY_MAX_DELAY_SEC=60
# 上下文预算：与网关/模型实际窗口对齐，避免 400 context exceeds；窄窗口示例 2048
# LLM_CONTEXT_WINDOW_TOKENS=8192
# LLM_RESERVED_COMPLETION_TOKENS=1024
# DATABASE_URL=sqlite+aiosqlite:///./forgeagent.db
# Agent：单次任务允许的重规划次数（可选，默认 3）
# MAX_REPLAN_ATTEMPTS=3
# ReAct agent loop：安全轮次上限（兜底，通常先触达墙钟或停滞超时）（可选，默认 512）
# MAX_REACT_ITERATIONS=512
# ReAct 单次任务墙钟上限（秒，默认 1800）
# REACT_AGENT_WALL_TIMEOUT_SEC=1800
# ReAct 无有效进展停滞阈值（秒，默认 180；超过则判定卡住并停止）
# REACT_AGENT_STALL_TIMEOUT_SEC=180
# 工具失败后的尝试次数上限：ReAct 为连续失败次数；Plan-Execute 为每步骤内执行次数（默认 3）
# MAX_TOOL_FAILURE_ATTEMPTS=3
# 多轮规划：注入 LLM 的最近会话消息条数上限（可选，默认 32）
# SESSION_MEMORY_MAX_MESSAGES=32
# LangGraph 检查点：默认 SQLite 文件路径（相对进程工作目录）
# LANGGRAPH_CHECKPOINT_SQLITE_PATH=./data/langgraph_checkpoints.db
# 若使用 Postgres 存检查点，设置 URI 并在 backend 目录执行: pip install -e ".[checkpoint-postgres]"
# LANGGRAPH_CHECKPOINT_POSTGRES_URI=postgresql://user:pass@localhost:5432/dbname
